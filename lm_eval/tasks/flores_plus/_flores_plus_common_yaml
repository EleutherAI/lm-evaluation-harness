custom_dataset: !function utils.load_dataset
output_type: generate_until
validation_split: dev
fewshot_split: dev
test_split: devtest
target_delimiter: ''
metric_list:
  - metric: bleu
    aggregation: bleu
    higher_is_better: true
  - metric: chrf
    aggregation: chrf
    higher_is_better: true
  - metric: ter
    aggregation: ter
    higher_is_better: false
generation_kwargs:
  until:
    - "\n"
  do_sample: false
  temperature: 0.0
repeats: 1
metadata:
  version: 1.0
