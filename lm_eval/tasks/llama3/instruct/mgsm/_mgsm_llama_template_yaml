dataset_path: juletxara/mgsm
output_type: generate_until
training_split: train
test_split: test
doc_to_text: "Solve the following math problem step by step. The last line of your response should be of the form \"The final answer is [ANSWER]\" where [ANSWER] is the numerical answer.\nQuestion: {{question}}\n"
doc_to_target: '{% if answer is not none %}{{answer[21:]}}{% else %}{{answer_number|string}}{% endif %}'
generation_kwargs:
  do_sample: false
  temperature: 0
  max_gen_toks: 1024
  until: []
num_fewshot: 0
filter_list:
  - name: strict-match
    filter:
      - function: regex
        regex_pattern: "final answer is (\\-?[0-9\\.\\,]+)"
      - function: take_first
  - name: flexible-extract
    filter:
      - function: regex
        group_select: -1
        regex_pattern: "(-?[$0-9.,]{2,})|(-?[0-9]+)"
      - function: take_first
metric_list:
  - metric: exact_match
    aggregation: mean
    higher_is_better: true
    ignore_case: true
    ignore_punctuation: true
metadata:
  version: 1.0